#!/usr/bin/env bash

# hash: {{ include "etc/systemd/logind.conf" | sha256sum }}

set -euo pipefail

CHEZMOI_SOURCE="${HOME}/.local/share/chezmoi"
SRC="${CHEZMOI_SOURCE}/etc/systemd/logind.conf"
DST="/etc/systemd/logind.conf"

if [[ -f "$SRC" ]]; then
    echo "Installing $DST..."
    sudo install -D -m 0755 "$SRC" "$DST"
fi
